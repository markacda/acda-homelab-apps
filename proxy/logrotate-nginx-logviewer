# Daily gzip rotation of the proxy's JSON access log for the Log Viewer, matching
# the ~30-day retention the Node apps get from rotating-file-stream. Invoked by
# busybox crond (see crontab-root); nginx reopens the file after each rotation so
# it keeps writing to the fresh access.log. log-viewer gunzips the rotated .gz
# history transparently.
/var/log/nginx/lv/access.log {
  daily
  rotate 30
  compress
  delaycompress
  missingok
  notifempty
  create 0644 root root
  sharedscripts
  postrotate
    nginx -s reopen 2>/dev/null || true
  endscript
}

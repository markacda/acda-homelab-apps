# Build context is the repo root (docker build -f apps/<app>/Dockerfile .).
# Keep it lean and free of host-built artifacts; each image installs its own
# deps and compiles fresh.
**/node_modules
**/dist
**/logs
**/data

# Compiled client bundles are regenerated by the build stage.
apps/*/public/*.js
apps/*/public/*.js.map

.git
.github
.claude
.gitignore
**/*.log
npm-debug.log*
.DS_Store
**/Dockerfile
**/.dockerignore
docker-compose.yml
**/README.md

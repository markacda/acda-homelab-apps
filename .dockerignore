# Build context is the repo root (docker build -f apps/<app>/Dockerfile .).
# Keep it lean and free of host-built artifacts; each image installs its own
# deps and compiles fresh.
**/node_modules
**/dist
**/logs
**/data

# Compiled client bundles are regenerated by the build stage.
apps/*/public/*.js
apps/*/public/*.js.map
apps/*/Web/public/*.js
apps/*/Web/public/*.js.map

.git
.github
.claude
.gitignore
**/*.log
npm-debug.log*
yarn-error.log
**/Dockerfile
**/.dockerignore
docker-compose.yml
**/README.md

# Editor / OS cruft (folded in from the former per-app .dockerignore files —
# the build context is the repo root, so only this file is ever consulted).
.idea
.vscode
*.swp
*.swo
*~
.DS_Store
Thumbs.db

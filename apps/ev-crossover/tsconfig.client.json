{
  // Browser side: compiles client/*.ts -> public/*.js (served static by
  // express.static). DOM libs only, no Node types. tsc rewrites the ".ts"
  // relative imports to ".js" so the emitted modules load over HTTP.
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "outDir": "./public",
    "rootDir": "./client",
    "types": [],
    "sourceMap": false
  },
  "include": ["client/**/*.ts"]
}

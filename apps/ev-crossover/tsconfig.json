{
  // Node side: server + lib + tests. Compiles to dist/ for production. The test
  // importing ../client/crossover.ts pulls that pure module into the program, so
  // it is type-checked here too.
  // rootDir is pinned to "../.." (repo root) so that, even though server.ts now
  // imports the shared kit from ../Common (a sibling under apps/), the emit still
  // nests the build as dist/apps/ev-crossover/server.js (see package.json "start").
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "../..",
    "types": ["node"]
  },
  "include": ["server.ts", "lib/**/*.ts", "test/**/*.ts"]
}

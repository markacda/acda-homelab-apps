{
  // Node side: server + lib + tests. Compiles to dist/ for production. The test
  // importing ../client/crossover.ts pulls that pure module into the program, so
  // it is type-checked here too.
  // No rootDir: server.ts imports the shared logger from ../../packages, which
  // sits above the app dir, so the common source root is the repo root and the
  // build nests as dist/apps/ev-crossover/server.js (see package.json "start").
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "types": ["node"]
  },
  "include": ["server.ts", "lib/**/*.ts", "test/**/*.ts"]
}

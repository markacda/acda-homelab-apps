{
  "name": "ev-crossover",
  "version": "1.0.0",
  "description": "Calculate the electricity price (€/kWh) at which charging the car becomes cheaper than petrol",
  "private": true,
  "type": "module",
  "main": "dist/apps/ev-crossover/server.js",
  "scripts": {
    "dev": "node --watch server.ts",
    "build": "tsc -p tsconfig.build.json && tsc -p tsconfig.client.json",
    "start": "node dist/apps/ev-crossover/server.js",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.client.json --noEmit",
    "test": "node --test",
    "clean": "rm -rf dist public/*.js"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "express": "^5.1.0",
    "rotating-file-stream": "^3.2.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "typescript": "^5.9.3"
  }
}

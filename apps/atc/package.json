{
  "name": "atc",
  "version": "1.0.0",
  "description": "ATC Frontend - Aircraft Tracking Application",
  "private": true,
  "type": "module",
  "main": "dist/apps/atc/server.js",
  "scripts": {
    "dev": "node --watch server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/apps/atc/server.js",
    "typecheck": "tsc --noEmit",
    "test": "node --test",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "express": "^5.1.0",
    "mqtt": "^5.10.1",
    "rotating-file-stream": "^3.2.6"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "typescript": "^5.9.3"
  }
}

{
  // Browser side: compiles Web/client/*.ts -> Web/public/*.js (served static by
  // express.static). DOM libs only, no Node types. tsc rewrites the ".ts"
  // relative imports to ".js" so the emitted modules load over HTTP.
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "outDir": "./Web/public",
    "rootDir": "./Web/client",
    "types": [],
    "sourceMap": false
  },
  "include": ["Web/client/**/*.ts"]
}

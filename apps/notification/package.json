{
  "name": "notification",
  "version": "1.0.0",
  "description": "Web Push fan-out for the homelab: stores subscriptions, sends notifications, keeps a recent-notifications feed",
  "private": true,
  "type": "module",
  "main": "dist/apps/notification/server.js",
  "scripts": {
    "dev": "node --watch server.ts",
    "build": "tsc -p tsconfig.build.json && tsc -p tsconfig.client.json",
    "start": "node dist/apps/notification/server.js",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.client.json --noEmit",
    "test": "node --test",
    "clean": "rm -rf dist Web/public/*.js"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "express": "^5.1.0",
    "rotating-file-stream": "^3.2.6",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/web-push": "^3.6.3",
    "typescript": "^5.9.3"
  }
}

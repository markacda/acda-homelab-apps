{
  "name": "dashboard",
  "version": "1.0.0",
  "description": "Tiled homelab dashboard with Docker auto-discovery and server-side health checks",
  "private": true,
  "type": "module",
  "main": "dist/apps/dashboard/server.js",
  "scripts": {
    "dev": "node --watch server.ts",
    "build": "tsc -p tsconfig.build.json && tsc -p tsconfig.client.json",
    "start": "node dist/apps/dashboard/server.js",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.client.json --noEmit",
    "test": "node --test",
    "clean": "rm -rf dist public/*.js"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "dockerode": "^4.0.2",
    "express": "^5.1.0",
    "js-yaml": "^4.1.0",
    "rotating-file-stream": "^3.2.6"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.31",
    "@types/express": "^5.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.0.0",
    "typescript": "^5.9.3"
  }
}

{
  "name": "dynamic-vs-fixed",
  "version": "1.0.0",
  "description": "Compare a fixed vs dynamic (hourly-market) NL energy contract using HomeWizard usage data",
  "private": true,
  "type": "module",
  "main": "dist/apps/dynamic-vs-fixed/server.js",
  "scripts": {
    "dev": "node --watch server.ts",
    "build": "tsc -p tsconfig.build.json && tsc -p tsconfig.client.json",
    "start": "node dist/apps/dynamic-vs-fixed/server.js",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.client.json --noEmit",
    "test": "node --test",
    "clean": "rm -rf dist Web/public/*.js"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "express": "^5.1.0",
    "luxon": "^3.5.0",
    "multer": "^2.0.1",
    "rotating-file-stream": "^3.2.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/luxon": "^3.4.2",
    "@types/multer": "^1.4.12",
    "@types/node": "^24.0.0",
    "typescript": "^5.9.3"
  }
}
